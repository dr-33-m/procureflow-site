---
import logoSvg from "../assets/procureflow2.svg";
---

<footer class="bg-secondary w-full border-t border-border">
  <div
    class="flex flex-col md:flex-row justify-between items-center py-20 px-8 max-w-screen-2xl mx-auto gap-12"
  >
    <div class="flex flex-col gap-4">
      <a href="/" class="flex items-center gap-2 text-primary">
        <img src={logoSvg.src} alt="ProcureFlow" class="h-7 object-contain" />
        <span class="text-xl font-bold text-primary tracking-tighter font-serif"
          >ProcureFlow</span
        >
      </a>
      <p
        class="text-sm font-semibold text-muted-foreground max-w-xs leading-relaxed"
      >
        Built by operators, for operators. Profit leak prevention for F&amp;B
        operations.
      </p>
    </div>
    <div
      class="flex flex-wrap justify-center gap-10 font-serif text-xs font-black uppercase tracking-widest"
    >
      <a class="text-foreground hover:text-primary transition-colors" href="#"
        >Privacy</a
      >
      <a class="text-foreground hover:text-primary transition-colors" href="#"
        >Terms</a
      >
      <a class="text-foreground hover:text-primary transition-colors" href="#"
        >Support</a
      >
    </div>
    <div
      class="font-serif text-xs font-bold uppercase tracking-widest text-muted-foreground text-center md:text-right leading-loose"
    >
      &copy; 2026 ProcureFlow.<br />
      <span class="text-[10px] opacity-70 font-black"
        >Profit Leak Prevention for F&amp;B Operations.</span
      >
    </div>
  </div>
</footer>
