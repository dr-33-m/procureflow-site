---
import { CircleCheck } from "@lucide/astro";
---

<section class="py-32 px-8 bg-card" id="pricing">
  <div class="max-w-screen-xl mx-auto">
    <div class="text-center mb-20">
      <h2
        class="font-serif text-[2rem] leading-[2.5rem] text-primary font-bold mb-4"
      >
        Choose your operational scale
      </h2>
      <p class="text-muted-foreground font-semibold text-lg">
        All plans include the full ProcureFlow platform. We charge for
        operational scale, not feature access.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 items-start">
      <!-- Starter -->
      <div
        class="bg-background p-12 rounded-2xl border border-border shadow-sm flex flex-col"
      >
        <h3
          class="font-serif text-[1.5rem] leading-8 text-foreground font-bold mb-1"
        >
          Starter
        </h3>
        <p class="text-muted-foreground font-medium text-sm mb-8">
          For single or small operations.
        </p>
        <div class="mb-8">
          <span class="text-5xl font-extrabold text-primary">$149</span>
          <span class="text-muted-foreground font-bold text-lg">/mo</span>
        </div>
        <ul class="space-y-3 mb-10 flex-grow">
          <li class="flex gap-3 text-foreground font-medium text-sm">
            <CircleCheck class="w-4 h-4 text-primary shrink-0 mt-0.5" />
            Up to 2 locations
          </li>
          <li class="flex gap-3 text-foreground font-medium text-sm">
            <CircleCheck class="w-4 h-4 text-primary shrink-0 mt-0.5" />
            Up to 10 users
          </li>
          <li class="flex gap-3 text-foreground font-medium text-sm">
            <CircleCheck class="w-4 h-4 text-primary shrink-0 mt-0.5" />
            Up to 6 stations
          </li>
          <li class="flex gap-3 text-foreground font-medium text-sm">
            <CircleCheck class="w-4 h-4 text-primary shrink-0 mt-0.5" />
            Up to 800 products
          </li>
        </ul>
        <button
          class="w-full py-3.5 rounded-lg font-semibold text-sm bg-secondary text-primary hover:bg-secondary/80 transition-all"
          >Select Starter</button
        >
      </div>

      <!-- Growth (Recommended) -->
      <div
        class="bg-background p-12 rounded-2xl flex flex-col shadow-2xl border-2 border-primary relative -mt-4 -mb-4 z-10"
      >
        <div
          class="absolute -top-4 left-1/2 -translate-x-1/2 bg-primary text-primary-foreground px-5 py-1.5 rounded-lg text-xs font-black uppercase tracking-[0.15em] shadow-md whitespace-nowrap"
        >
          Most Popular
        </div>
        <h3
          class="font-serif text-[1.5rem] leading-8 text-foreground font-black mb-1 mt-2"
        >
          Growth
        </h3>
        <p class="text-muted-foreground font-bold text-sm mb-8">
          For expanding operations.
        </p>
        <div class="mb-8">
          <span class="text-5xl font-extrabold text-primary">$399</span>
          <span class="text-muted-foreground font-bold text-lg">/mo</span>
        </div>
        <ul class="space-y-3 mb-10 flex-grow">
          <li class="flex gap-3 text-foreground font-medium text-sm">
            <CircleCheck class="w-4 h-4 text-primary shrink-0 mt-0.5" />
            Up to 5 locations
          </li>
          <li class="flex gap-3 text-foreground font-medium text-sm">
            <CircleCheck class="w-4 h-4 text-primary shrink-0 mt-0.5" />
            Up to 25 users
          </li>
          <li class="flex gap-3 text-foreground font-medium text-sm">
            <CircleCheck class="w-4 h-4 text-primary shrink-0 mt-0.5" />
            Up to 12 stations
          </li>
          <li class="flex gap-3 text-foreground font-medium text-sm">
            <CircleCheck class="w-4 h-4 text-primary shrink-0 mt-0.5" />
            Up to 2,000 products
          </li>
        </ul>
        <button
          class="w-full py-3.5 rounded-lg font-semibold text-sm bg-primary text-primary-foreground hover:bg-primary/90 transition-all shadow-lg shadow-primary/20"
          >Select Growth</button
        >
      </div>

      <!-- Pro -->
      <div
        class="bg-background p-12 rounded-2xl border border-border shadow-sm flex flex-col"
      >
        <h3
          class="font-serif text-[1.5rem] leading-8 text-foreground font-bold mb-1"
        >
          Pro
        </h3>
        <p class="text-muted-foreground font-medium text-sm mb-8">
          For large, complex operations.
        </p>
        <div class="mb-8">
          <span class="text-5xl font-extrabold text-primary">$899</span>
          <span class="text-muted-foreground font-bold text-lg">/mo</span>
        </div>
        <ul class="space-y-3 mb-10 flex-grow">
          <li class="flex gap-3 text-foreground font-medium text-sm">
            <CircleCheck class="w-4 h-4 text-primary shrink-0 mt-0.5" />
            Up to 15 locations
          </li>
          <li class="flex gap-3 text-foreground font-medium text-sm">
            <CircleCheck class="w-4 h-4 text-primary shrink-0 mt-0.5" />
            Up to 75 users
          </li>
          <li class="flex gap-3 text-foreground font-medium text-sm">
            <CircleCheck class="w-4 h-4 text-primary shrink-0 mt-0.5" />
            Up to 30 stations
          </li>
          <li class="flex gap-3 text-foreground font-medium text-sm">
            <CircleCheck class="w-4 h-4 text-primary shrink-0 mt-0.5" />
            Up to 10,000 products
          </li>
        </ul>
        <button
          class="w-full py-3.5 rounded-lg font-semibold text-sm bg-secondary text-primary hover:bg-secondary/80 transition-all"
          >Contact Sales</button
        >
      </div>
    </div>
  </div>
</section>
